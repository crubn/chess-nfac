# App URL (used in checkout successUrl; must match your deployed origin)
# Checkout route appends /order/success?checkout_id={CHECKOUT_ID} per Polar’s Next.js guide
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Polar (https://polar.sh/docs) — org access token for checkout API
POLAR_ACCESS_TOKEN=
# webhook signing secret (Polar dashboard → Webhooks)
POLAR_WEBHOOK_SECRET=
# Test product id from Polar dashboard
POLAR_PRO_PRODUCT_ID=
# Optional: "sandbox" | "production" (see @polar-sh/sdk)
POLAR_SERVER=sandbox

# Local dev: force Pro in API (optional)
SUBSCRIPTION_MOCK_PRO=
NEXT_PUBLIC_SUBSCRIPTION_MOCK=

# Supabase (optional; wire in syncProToDatabase.ts)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Realtime Multiplayer (client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Coach (getCoachInsight) — set one; Groq is preferred if both exist
OPENAI_API_KEY=
# GROQ_API_KEY=

# Legacy: if set, missing token still allowed demo success (redundant with current redirect)
# ALLOW_DEMO_CHECKOUT=1
